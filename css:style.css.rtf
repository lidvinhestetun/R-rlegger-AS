\}\
\
.brand-logo \{\
    width: 40px;\
    height: 40px;\
    border-radius: 14px;\
    background: radial-gradient(circle at 30% 20%, #38bdf8, #0f172a);\
    display: flex;\
    align-items: center;\
    justify-content: center;\
    box-shadow: 0 12px 30px rgba(56, 189, 248, 0.45);\
