\}\
\
.faq-item \{\
    border-radius: var(--radius-md);\
    border: 1px solid rgba(148, 163, 184, 0.35);\
    background: rgba(15, 23, 42, 0.9);\
    overflow: hidden;\
\}\
\
.faq-question \{\
    width: 100%;\
    padding: 0.7rem 0.9rem;\
    background: transparent;\
    border: none;\
    color: var(--color-text);\
    display: flex;\
    align-items: center;\
    justify-content: space-between;\
    font-size: 0.9rem;\
    cursor: pointer;\
\}\
\
.faq-toggle-icon \{\
    font-size: 1.1rem;\
    color: var(--color-text-soft);\
    transition: transform 0.2s ease;\
\}\
\
.faq-item.is-open .faq-toggle-icon \{\
    transform: rotate(45deg);\
\}\
\
.faq-answer \{\
    max-height: 0;\
    overflow: hidden;\
    padding: 0 0.9rem;\
    font-size: 0.88rem;\
    color: var(--color-text-soft);\
    transition: max-height 0.25s ease, padding-bottom 0.25s ease;\
\}\
\
.faq-answer p \{\
    margin: 0.4rem 0 0.8rem;\
\}\
\
.faq-item.is-open .faq-answer \{\
    max-height: 200px;\
    padding-bottom: 0.6rem;\
\}\
\
/* =========================\
   CONTACT\
   ========================= */\
\
.contact-grid \{\
    display: grid;\
    grid-template-columns: minmax(0, 1.3fr) minmax(0, 1.1fr);\
    gap: 2.2rem;\
    align-items: flex-start;\
\}\
\
.contact-info \{\
    display: grid;\
    grid-template-columns: repeat(2, minmax(0, 1fr));\
    gap: 1.2rem;\
    margin-top: 1.2rem;\
\}\
\
.contact-info-block \{\
    border-radius: var(--radius-md);\
    border: 1px solid rgba(148, 163, 184, 0.4);\
    background: radial-gradient(circle at top left, rgba(15, 23, 42, 0.9), rgba(15, 23, 42, 0.98));\
    padding: 1rem 0.9rem;\
    font-size: 0.9rem;\
    color: var(--color-text-soft);\
\}\
\
.contact-info-title \{\
    margin: 0 0 0.4rem;\
    font-size: 0.95rem;\
    color: var(--color-text);\
\}\
\
.contact-form-wrapper \{\
    padding: 1.4rem 1.3rem;\
\}\
\
.contact-form-title \{\
    margin: 0 0 0.4rem;\
    font-size: 1rem;\
\}\
\
.contact-form-text \{\
    margin: 0 0 0.9rem;\
    font-size: 0.88rem;\
    color: var(--color-text-soft);\
\}\
\
.contact-form \{\
    display: grid;\
    gap: 0.7rem;\
\}\
\
.form-row \{\
    display: grid;\
    grid-template-columns: repeat(2, minmax(0, 1fr));\
    gap: 0.7rem;\
\}\
\
.form-field \{\
    display: flex;\
    flex-direction: column;\
    gap: 0.25rem;\
    font-size: 0.85rem;\
    color: var(--color-text-soft);\
\}\
\
.form-field span \{\
    font-size: 0.8rem;\
\}\
\
.form-field input,\
.form-field select,\
.form-field textarea \{\
    border-radius: var(--radius-md);\
    border: 1px solid rgba(148, 163, 184, 0.5);\
    background: rgba(15, 23, 42, 0.9);\
    padding: 0.5rem 0.55rem;\
    color: var(--color-text);\
    font-size: 0.9rem;\
\}\
\
.form-field input::placeholder,\
.form-field textarea::placeholder \{\
    color: var(--color-text-muted);\
\}\
\
.form-field input:focus,\
.form-field select:focus,\
.form-field textarea:focus \{\
    outline: 2px solid rgba(56, 189, 248, 0.7);\
    outline-offset: 1px;\
    border-color: rgba(56, 189, 248, 0.8);\
\}\
\
.form-field-inline \{\
    flex-direction: row;\
    align-items: flex-start;\
    gap: 0.4rem;\
\}\
\
.form-field-inline input[type="checkbox"] \{\
    width: 16px;\
    height: 16px;\
    margin-top: 0.1rem;\
\}\
\
.form-footnote \{\
    margin: 0;\
    font-size: 0.78rem;\
    color: var(--color-text-muted);\
\}\
\
.contact-form button[disabled] \{\
    opacity: 0.7;\
    cursor: not-allowed;\
\}\
\
/* =========================\
   FOOTER\
   ========================= */\
\
.footer \{\
    border-top: 1px solid rgba(148, 163, 184, 0.25);\
    padding: 1.6rem 0 1.8rem;\
    background: radial-gradient(circle at top, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.98));\
\}\
\
.footer-inner \{\
    display: grid;\
    grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr) minmax(0, 1.2fr);\
    gap: 1.4rem;\
    align-items: center;\
    font-size: 0.8rem;\
    color: var(--color-text-soft);\
\}\
\
.footer-brand \{\
    display: flex;\
    align-items: center;\
    gap: 0.75rem;\
\}\
\
.footer-links \{\
    display: flex;\
    justify-content: center;\
    gap: 1rem;\
\}\
\
.footer-link \{\
    color: var(--color-text-muted);\
    font-size: 0.8rem;\
\}\
\
.footer-link:hover \{\
    color: var(--color-primary);\
\}\
\
.footer-meta \{\
    display: flex;\
    flex-direction: column;\
    align-items: flex-end;\
    gap: 0.2rem;\
\}\
\
/* =========================\
   UTILITIES\
   ========================= */\
\
.text-center \{\
    text-align: center;\
\}\
\
.text-right \{\
    text-align: right;\
\}\
\
.mt-1 \{\
    margin-top: 0.25rem;\
\}\
\
.mt-2 \{\
    margin-top: 0.5rem;\
\}\
\
.mt-3 \{\
    margin-top: 0.75rem;\
\}\
\
.mt-4 \{\
    margin-top: 1rem;\
\}\
\
.mb-1 \{\
    margin-bottom: 0.25rem;\
\}\
\
.mb-2 \{\
    margin-bottom: 0.5rem;\
\}\
\
.mb-3 \{\
    margin-bottom: 0.75rem;\
\}\
\
.mb-4 \{\
    margin-bottom: 1rem;\
\}\
\
/* =========================\
   RESPONSIVE\
   ========================= */\
\
@media (max-width: 1024px) \{\
    .hero-inner \{\
        grid-template-columns: minmax(0, 1.3fr) minmax(0, 1.1fr);\
        gap: 2.2rem;\
    \}\
\
    .service-grid \{\
        grid-template-columns: repeat(2, minmax(0, 1fr));\
    \}\
\
    .project-grid \{\
        grid-template-columns: repeat(2, minmax(0, 1fr));\
    \}\
\
    .review-grid \{\
        grid-template-columns: repeat(2, minmax(0, 1fr));\
    \}\
\
    .about-grid \{\
        grid-template-columns: minmax(0, 1.4fr) minmax(0, 1.1fr);\
    \}\
\
    .contact-grid \{\
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 1.1fr);\
    \}\
\
    .footer-inner \{\
        grid-template-columns: minmax(0, 1.2fr) minmax(0, 1.2fr);\
        grid-template-rows: auto auto;\
    \}\
\
    .footer-meta \{\
        align-items: flex-start;\
    \}\
\}\
\
@media (max-width: 768px) \{\
    .navbar-inner \{\
        height: auto;\
        padding: 0.6rem 0;\
    \}\
\
    .navbar-nav \{\
        position: fixed;\
        inset: var(--nav-height) 0 auto 0;\
        top: 60px;\
        background: radial-gradient(circle at top, rgba(15, 23, 42, 0.98), rgba(15, 23, 42, 0.98));\
        flex-direction: column;\
        align-items: flex-start;\
        padding: 0.8rem 1.5rem 1.2rem;\
        gap: 0.6rem;\
        transform: translateY(-120%);\
        opacity: 0;\
        pointer-events: none;\
        transition: transform 0.2s ease, opacity 0.2s ease;\
    \}\
\
    .navbar-nav.is-open \{\
        transform: translateY(0);\
        opacity: 1;\
        pointer-events: auto;\
    \}\
\
    .navbar-toggle \{\
        display: flex;\
    \}\
\
    .hero \{\
        padding-top: 2.5rem;\
    \}\
\
    .hero-inner \{\
        grid-template-columns: minmax(0, 1fr);\
    \}\
\
    .hero-panel \{\
        justify-content: flex-start;\
    \}\
\
    .trust-inner \{\
        grid-template-columns: minmax(0, 1fr);\
    \}\
\
    .service-grid \{\
        grid-template-columns: minmax(0, 1fr);\
    \}\
\
    .project-grid \{\
        grid-template-columns: minmax(0, 1fr);\
    \}\
\
    .review-grid \{\
        grid-template-columns: minmax(0, 1fr);\
    \}\
\
    .about-grid \{\
        grid-template-columns: minmax(0, 1fr);\
    \}\
\
    .contact-grid \{\
        grid-template-columns: minmax(0, 1fr);\
    \}\
\
    .contact-info \{\
        grid-template-columns: minmax(0, 1fr);\
    \}\
\
    .form-row \{\
        grid-template-columns: minmax(0, 1fr);\
    \}\
\
    .footer-inner \{\
        grid-template-columns: minmax(0, 1fr);\
        text-align: left;\
    \}\
\
    .footer-links \{\
        justify-content: flex-start;\
    \}\
\
    .footer-meta \{\
        align-items: flex-start;\
    \}\
\}\
\
@media (max-width: 480px) \{\
    .hero-title \{\
        font-size: 2.1rem;\
    \}\
\
    .section \{\
        padding: 3rem 0;\
    \}\
\
    .hero-panel-card \{\
        max-width: 100%;\
    \}\
\}\
}