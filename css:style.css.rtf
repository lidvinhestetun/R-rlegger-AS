/* =========================\
   CSS VARIABLES\
   ========================= */\
\
:root \{\
    --color-bg: #020617;\
    --color-bg-elevated: rgba(15, 23, 42, 0.9);\
    --color-bg-soft: rgba(15, 23, 42, 0.7);\
    --color-surface: #020617;\
    --color-surface-alt: #020617;\
    --color-border-subtle: rgba(148, 163, 184, 0.25);\
    --color-border-strong: rgba(148, 163, 184, 0.5);\
    --color-primary: #38bdf8;\
    --color-primary-soft: rgba(56, 189, 248, 0.15);\
    --color-primary-strong: #0ea5e9;\
    --color-accent: #22c55e;\
    --color-text: #e5e7eb;\
    --color-text-soft: #9ca3af;\
    --color-text-muted: #6b7280;\
    --color-danger: #ef4444;\
    --shadow-soft: 0 18px 45px rgba(15, 23, 42, 0.75);\
    --radius-lg: 18px;\
    --radius-md: 12px;\
    --radius-sm: 8px;\
    --radius-pill: 999px;\
    --container-width: 1120px;\
    --nav-height: 70px;\
\}\
\
/* =========================\
   LAYOUT HELPERS\
   ========================= */\
\
.page-wrapper \{\
    min-height: 100vh;\
    background:\
        radial-gradient(circle at top left, rgba(56, 189, 248, 0.18), transparent 55%),\
        radial-gradient(circle at bottom right, rgba(34, 197, 94, 0.18), transparent 55%),\
        radial-gradient(circle at top right, rgba(59, 130, 246, 0.12), transparent 55%),\
        #020617;\
    color: var(--color-text);\
\}\
\
.container \{\
    width: 100%;\
    max-width: var(--container-width);\
    margin: 0 auto;\
    padding: 0 1.5rem;\
\}\
\
/* =========================\
   NAVBAR\
   ========================= */\
\
.navbar \{\
    position: sticky;\
    top: 0;\
    z-index: 50;\
    backdrop-filter: blur(18px);\
    background: linear-gradient(to bottom, rgba(15, 23, 42, 0.96), rgba(15, 23, 42, 0.85));\
    border-bottom: 1px solid rgba(148, 163, 184, 0.25);\
\}\
\
.navbar-inner \{\
    display: flex;\
    align-items: center;\
    justify-content: space-between;\
    height: var(--nav-height);\
\}\
\
.navbar-brand \{\
    display: flex;\
